# ============================================================================
# Ancroo Voice Configuration
# ============================================================================
# This file is named:
#   - .env on Linux
#   - ancroo-voice.ini on Windows
# The format is the same on both platforms.
#
# ============================================================================
# Ancroo Backend
# ============================================================================
# Connects to the Ancroo Backend (default port 8900), which manages STT
# model and server selection centrally. Change localhost to your server IP/hostname.
#
# NOTE: This points to the Ancroo Backend, NOT directly to Whisper/STT.
# The backend must have at least one STT provider registered:
#   → Admin UI: http://your-server:8900/admin/stt-providers
ANCROO_BACKEND_ENDPOINT=http://localhost:8900/api/v1/transcribe
# ANCROO_BACKEND_API_KEY=your_api_key_here  # Optional, only if your backend requires authentication
# ANCROO_BACKEND_VERIFY_SSL=false  # Set to false for self-signed certificates

# ============================================================================
# Settings Persistence
# ============================================================================
# All settings are automatically saved in ancroo-voice_config.json when you
# click "Start" in the GUI. The last used settings will be restored when you
# restart the application.
#
# Only API keys and endpoints need to be configured in this file.
# Everything else (Language, Microphone, Hotkey) can be configured in the GUI!
